# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI APIs
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Arcjet (bot/shield protection on the AI routes; optional — routes work without it)
ARCJET_KEY=

# Sentry (error tracking; optional — DSN is public/client-safe. SDK is a no-op when unset)
NEXT_PUBLIC_SENTRY_DSN=
# Optional: only needed to upload source maps during the build (CI/prod)
SENTRY_AUTH_TOKEN=

# PostHog (product analytics; optional — project token is public/client-safe. No-op when unset)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Landing contact form — Gmail SMTP (App Password, NOT your normal password).
# Create at https://myaccount.google.com/apppasswords (requires 2-Step Verification).
# GMAIL_USER also becomes the "from" address; CONTACT_TO_EMAIL is where enquiries
# are delivered (defaults to GMAIL_USER if left blank).
GMAIL_USER=
GMAIL_APP_PASSWORD=
CONTACT_TO_EMAIL=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe (required for the new subscription plan: payment links, self-service upgrade/cancel UI, billing admin & webhooks)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
